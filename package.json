    "date-fns": "^4.1.0",
    "fastest-levenshtein": "^1.0.16",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "nanospinner": "^1.2.0",
    "picocolors": "^1.1.0",
